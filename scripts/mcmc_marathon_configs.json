{
  "version": 1,
  "description": "MCMC Tier S 探索組合（6 entry）。供 run_mcmc_marathon.ps1 過夜批次使用。",
  "global_defaults": {
    "imgdir": "data\\frames_1600",
    "colmap": "outputs\\SfM_models\\sift\\sparse\\0",
    "validation_report": "outputs\\reports\\pointcloud_validation_report.json",
    "outdir_root": "outputs\\experiments\\mcmc_marathon",
    "data_factor": 1,
    "sh_degree": 3,
    "eval_steps": 1000,
    "disable_video": true
  },
  "probes": [
    {
      "id": "01_refine25k_full",
      "tier": "S",
      "rationale": "修 wrapper bug：MCMC 預設 refine_stop_iter 應為 25000 而非 15000。對照 1M baseline LPIPS 0.19187（過去在『假 25k』下達成）。",
      "expected_eta_hours": 8,
      "iterations": 30000,
      "train_mode": "mcmc",
      "cap_max": 1000000,
      "antialiased": false,
      "extra_args": []
    },
    {
      "id": "02_noisestop22k_full",
      "tier": "S",
      "rationale": "Unity 視覺霧化的可能直接解：提早 8000 iter 停止噪聲注入（MCMCStrategy 預設永不停）。配 750k+AA Unity 候選。",
      "expected_eta_hours": 8,
      "iterations": 30000,
      "train_mode": "mcmc",
      "cap_max": 750000,
      "antialiased": true,
      "mcmc_noise_injection_stop_iter": 22000,
      "extra_args": []
    },
    {
      "id": "03_ssim03_probe",
      "tier": "S",
      "rationale": "DSSIM 損失權重從 0.2 → 0.3，強化結構保真。對照 Scaffold-GS sandbox 同條件。",
      "expected_eta_hours": 2,
      "iterations": 7000,
      "train_mode": "mcmc",
      "cap_max": 750000,
      "antialiased": true,
      "ssim_lambda": 0.3,
      "extra_args": []
    },
    {
      "id": "04_bilagrid_probe",
      "tier": "S",
      "rationale": "新方法：bilateral grid 校正影像曝光不一致 / rolling shutter。853 張連拍如有微曝光差，這直接修。",
      "expected_eta_hours": 2,
      "iterations": 7000,
      "train_mode": "mcmc",
      "cap_max": 750000,
      "antialiased": true,
      "use_bilateral_grid": true,
      "extra_args": []
    },
    {
      "id": "05_depth_probe",
      "tier": "S",
      "rationale": "depth loss 監督。金屬反光最大失敗模式就是深度被誤判，深度監督可能直接修。注意：需要 colmap depth 可用。",
      "expected_eta_hours": 2,
      "iterations": 7000,
      "train_mode": "mcmc",
      "cap_max": 750000,
      "antialiased": true,
      "depth_loss": true,
      "extra_args": []
    },
    {
      "id": "06_with_ut_probe",
      "tier": "S",
      "rationale": "Unscented Transform rasterization。新版 EWA 替代，對高頻細節 / antialiased 場景特別穩。",
      "expected_eta_hours": 2,
      "iterations": 7000,
      "train_mode": "mcmc",
      "cap_max": 750000,
      "antialiased": true,
      "with_ut": true,
      "extra_args": []
    }
  ]
}
