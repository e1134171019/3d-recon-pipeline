[run]
source =
    src.preprocess_phase0
    src.downscale_frames
    src.sfm_colmap
    src.train_3dgs
    src.export_ply
    src.export_ply_unity

[report]
show_missing = True
skip_covered = False
omit =
    */__pycache__/*
    outputs/*
    scripts/*
    gsplat_runner/*
    unity_setup/*
    test_cuda.py
    src/__init__.py
    src/utils/*

[json]
pretty_print = True
